  "case_notes": [
    {
      "note_id": "NOTE-SD-001",
      "member_id": "MBR-ANCHOR-D",
      "case_id": "CASE-SD-001",
      "author": "Marcus Williams",
      "created_date": "2025-10-22 00:00:00",
      "category": "Claim Denial Inquiry",
      "note_type": "Manual",
      "content": "Member called regarding denied anesthesia claim CLM-SD-014 ($4,200). Member gave birth at University Hospital on 10/5/2025 and received epidural anesthesia during labor. The anesthesiologist (Dr. Kowalski) was assigned by the hospital — member had no choice or advance notice that the provider was out-of-network. Member is extremely upset about receiving a $4,200 balance bill. Explained that the claim was denied because the anesthesiologist is not in our Blue Access network. Member referenced the No Surprises Act, which protects patients from surprise out-of-network billing at in-network facilities. Initiated appeal under surprise billing protections. Advised member that this type of appeal is typically resolved in the patient's favor. Member remains very frustrated but appreciates the escalation. Case flagged as high priority.",
      "related_claim_id": "CLM-SD-014",
      "related_auth_id": null,
      "follow_up_required": true,
      "follow_up_date": "2025-11-22",
      "status": "Closed"
    },
    {
      "note_id": "NOTE-SD-002",
      "member_id": "MBR-ANCHOR-D",
      "case_id": "CASE-SD-001",
      "author": "Marcus Williams",
      "created_date": "2025-11-20 00:00:00",
      "category": "Appeal Resolution",
      "note_type": "Manual",
      "content": "Appeal for anesthesia claim CLM-SD-014 approved. No Surprises Act applies — patient received emergency/ancillary services from an out-of-network provider at an in-network facility without ability to choose an in-network alternative. Original denied claim voided. New claim CLM-SD-015 processed using qualifying payment amount (in-network median rate). Member responsibility reduced from $4,200 to $308 (standard coinsurance after deductible). Difference of $3,892 paid by plan. Member notified by mail and secure message. Case closed.",
      "related_claim_id": "CLM-SD-015",
      "related_auth_id": null,
      "follow_up_required": false,
      "follow_up_date": null,
      "status": "Closed"
    }
  ],

  "call_logs": [
    {
      "call_id": "CALL-SD-001",
      "member_id": "MBR-ANCHOR-D",
      "agent_id": "AGT-0003",
      "call_date": "2025-10-22",
      "call_time": "09:42:00",
      "duration_seconds": 1140,
      "call_type": "Inbound",
      "call_reason": "Surprise Billing Dispute",
      "disposition": "Escalated",
      "related_claim_id": "CLM-SD-014",
      "related_auth_id": null,
      "sentiment": "Very Negative",
      "notes": "Member called about a $4,200 balance bill for anesthesia during her delivery at University Hospital. She is extremely upset — she delivered at an in-network hospital and had no say in which anesthesiologist was assigned. The hospital assigned Dr. Kowalski (out-of-network) without informing her. Member states she specifically verified the hospital was in-network before delivery. Member is aware of the No Surprises Act and believes this is a clear violation. She is emotional (first baby, already dealing with new parenthood) and feels the system failed her. Agent acknowledged the situation, confirmed this appears to qualify for surprise billing protections, and initiated an appeal. Call escalated to supervisor for expedited processing. Supervisor assured member the appeal would be prioritized. Member wants written confirmation of appeal filing.",
      "queue_wait_seconds": 180,
      "first_call_resolution": false,
      "ivr_path": "1 > 2 > 3 > Agent"
    }
  ],

  "secure_messages": [
    {
      "message_id": "MSG-SD-001",
      "thread_id": "THD-SD-001",
      "member_id": "MBR-ANCHOR-D",
      "direction": "Inbound",
      "sent_date": "2025-09-20 00:00:00",
      "subject": "What's covered for delivery at University Hospital?",
      "body": "Hi, I'm 38 weeks pregnant and planning to deliver at University Hospital in Portland. I want to make sure I understand what's covered under my plan. Can you confirm: (1) University Hospital is in-network, (2) what my estimated out-of-pocket will be for a vaginal delivery with a 2-night stay, and (3) whether the anesthesia for an epidural is included? This is my first baby and I want to avoid any surprise bills. Thank you!",
      "category": "Benefits Inquiry",
      "status": "Replied",
      "related_claim_id": null,
      "priority": "Medium",
      "response_time_hours": 14
    },
    {
      "message_id": "MSG-SD-002",
      "thread_id": "THD-SD-002",
      "member_id": "MBR-ANCHOR-D",
      "direction": "Inbound",
      "sent_date": "2025-10-23 00:00:00",
      "subject": "Formal Complaint: Surprise $4,200 Anesthesia Bill",
      "body": "I am filing a formal complaint about claim CLM-SD-014. I delivered my baby at University Hospital on October 5th — an in-network facility that I verified in advance (see my message from September). Despite this, I received a $4,200 bill because the anesthesiologist assigned by the hospital was out-of-network. I had ZERO choice in this. I was in active labor. I specifically asked about coverage beforehand. This is exactly the kind of surprise billing the No Surprises Act was created to prevent. I called yesterday (reference CASE-SD-001) and was told an appeal was filed, but I want this complaint formally documented. If this is not resolved, I will file a complaint with the Oregon Division of Financial Regulation. This has been an incredibly stressful experience during what should be a happy time.",
      "category": "Complaint",
      "status": "Replied",
      "related_claim_id": "CLM-SD-014",
      "priority": "High",
      "response_time_hours": 8
    }
  ],

